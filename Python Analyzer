import csv
import os


class SalesAnalyzer:
	"""Analyze sales records loaded from a CSV file."""

	def __init__(self, filename):
		"""Store the CSV filename and prepare the in-memory sales records."""
		self.filename = filename
		self.data = []

	def load_data(self):
		"""Load sales rows from the CSV file into memory."""
		file_path = self.filename
		if not os.path.exists(file_path):
			fallback_path = os.path.join(os.path.dirname(__file__), "Python Sales")
			if os.path.exists(fallback_path):
				file_path = fallback_path

		with open(file_path, mode="r") as file:
			csv_reader = csv.DictReader(file)
			self.data = list(csv_reader)

	def calculate_total_sales(self):
		"""Calculate the total revenue across all loaded sales rows."""
		total = 0.0

		for row in self.data:
			price = float(row["price"])
			quantity = int(row["quantity"])
			total += price * quantity

		return total

	def find_top_product(self):
		"""Return the product with the highest total revenue from the loaded data."""
		top_product = None
		highest_sales = 0.0

		for row in self.data:
			product_sales = float(row["price"]) * int(row["quantity"])
			if product_sales > highest_sales:
				highest_sales = product_sales
				top_product = row["product_name"]

		return top_product


if __name__ == "__main__":
	sales_data_file = "sales_data.csv"
	analyzer = SalesAnalyzer(sales_data_file)
	analyzer.load_data()
	total_sales = analyzer.calculate_total_sales()
	analyzer.find_top_product()

	print(f"Total sales from {sales_data_file}: ${total_sales:.2f}")
